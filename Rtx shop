 .hero h2{font-size:42px;margin-bottom:10px;color:var(--white)}
 .hero p{font-size:18px;margin-bottom:25px;color:#ddd}
 .btn{background:var(--red);padding:14px 28px;border-radius:6px;font-weight:bold;display:inline-block;transition:0.3s}
 .btn:hover{background:#b30000;transform:scale(1.05)}
  
  /* Products */
 .products{padding:60px 20px;background:var(--grey)}
 .products h3{text-align:center;font-size:32px;margin-bottom:10px;color:var(--red)}
 .products.sub{text-align:center;margin-bottom:40px;color:#bbb}
 .grid{display:grid;grid-template-columns:repeat(auto-fit, minmax(300px, 1fr));gap:25px}
 .card{background:#111;padding:15px;border-radius:12px;border:1px solid #333;transition:0.3s}
 .card:hover{border-color:var(--red);transform:translateY(-5px)}
 .card img{width:100%;height:250px;object-fit:cover;border-radius:8px;margin-bottom:12px;border:2px solid var(--grey)}
 .badge{background:var(--red);padding:4px 10px;border-radius:4px;font-size:12px;font-weight:bold;display:inline-block;margin-bottom:8px}
 .card h4{color:var(--white);margin-bottom:5px;font-size:16px}
 .brand{color:#aaa;font-size:13px;margin-bottom:8px}
 .price{font-size:22px;font-weight:bold;color:var(--red);margin:10px 0}
 .old-price{text-decoration:line-through;color:#888;font-size:14px;margin-left:8px}
 .whatsapp-btn{background:#25D366;text-align:center;padding:12px;border-radius:6px;display:block;font-weight:bold}
 .whatsapp-btn:hover{background:#1ebe5a}
  
  /* About */
 .about{background:#111;padding:60px 20px;text-align:center}
 .about h3{color:var(--red);font-size:28px;margin-bottom:15px}
  
  /* Footer */
  footer{background:#000;text-align:center;padding:30px 20px;border-top:3px solid var(--red)}
 .contact{color:var(--red);font-size:20px;font-weight:bold}
  
